diff --git a/tests/test_importer.py b/tests/test_importer.py
--- a/tests/test_importer.py
+++ b/tests/test_importer.py
@@
     assert evidence["regime_replay"]["aggregate"]["worst_drawdown"]["max"] == 0.03
     assert evidence["promotion"]["status"] is None
+
+
+def test_run_evidence_surfaces_promotion_attempt_analytics(tmp_path: Path) -> None:
+    paths = build_fixture(tmp_path / "fixture")
+    ledger_dir = Path(paths["ledger_dir"])
+    _, export_paths = write_platform_export(
+        ledger_entries=read_ledger_entries(ledger_dir),
+        outcome_entries=read_outcome_entries(ledger_dir),
+        regime_entries=read_regime_entries(ledger_dir),
+        ledger_dir=ledger_dir,
+        output_dir=tmp_path / "exports",
+        discover_promotions=True,
+    )
+    db_path = tmp_path / "platform.sqlite"
+
+    ingest_bundle(export_paths["export_dir"], db_path=db_path)
+
+    evidence = get_run_evidence("run_ci_3", db_path=db_path)
+    promotion = evidence["promotion"]
+    attempts = promotion["attempts"]
+    latest_report = promotion["latest_attempt_report"]
+
+    assert evidence["ready"] is True
+    assert promotion["count"] == 2
+    assert promotion["latest_promotion_id"] == "promotion_ci_promoted"
+    assert promotion["status"] == "promoted"
+    assert attempts["attempt_count"] == 2
+    assert attempts["latest"]["promotion_id"] == "promotion_ci_promoted"
+    assert attempts["categories"]["top"][0]["category"] == "backtest"
+    assert attempts["categories"]["top"][0]["count"] == 1
+    assert latest_report["latest"]["promotion_id"] == "promotion_ci_promoted"
+    assert latest_report["categories"]["unique_count"] == 0
