{
  "schema_version": "agent-harness.trust-policy.v1",
  "allowed_dirty": [
    {
      "id": "docs-only-runbook",
      "repo": "agent-harness-ledger",
      "patterns": [
        "README.md",
        "docs/*.md"
      ],
      "statuses": [
        "M"
      ],
      "reason": "Documentation-only runbook updates do not alter capital calculations.",
      "expires_at": "2027-01-01"
    }
  ],
  "blocked_dirty": [
    {
      "id": "capital-engine-code-must-be-committed",
      "repo": "monte-carlo",
      "patterns": [
        "*.py",
        "tests/*.py",
        "pyproject.toml",
        "package.json"
      ],
      "statuses": [
        "*"
      ],
      "reason": "Capital-engine code, tests, and dependency changes must be committed before promotion."
    }
  ]
}
